<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EEEEEE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/pigID"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#PG-1024"
                android:textColor="@color/db_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pigStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="#E8F5E9"
                android:padding="6dp"
                android:text="Ahead"
                android:textColor="@color/db_dark_green"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Pig Image positioned BELOW ID -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/pigImage"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:src="@drawable/pig4"
                app:shapeAppearanceOverlay="@style/Widget.MaterialComponents.ShapeableImageView"
                app:strokeColor="@color/neon_orange"
                app:strokeWidth="1dp" />

            <!-- EDIT (Pencil) Icon instead of camera -->
            <ImageButton
                android:id="@+id/btnEditPigImage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignEnd="@id/pigImage"
                android:layout_alignBottom="@id/pigImage"
                android:layout_margin="8dp"
                android:background="@drawable/profile_gradient_bg"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/white"
                android:elevation="4dp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/pigBatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Batch: B-2024-MAR"
            android:textColor="@color/db_text_secondary"
            android:textSize="13sp" />

        <!-- WEIGHT AND PROGRESS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/pigWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Weight: 85 kg"
                android:textColor="@color/db_text_primary"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/growthProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="70"
                android:progressBackgroundTint="#E0E0E0"
                android:progressTint="@color/neon_orange" />

        </LinearLayout>

        <!-- ACTION BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/historyBtn"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="@color/neon_orange" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/updateBtn"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update"
                android:textColor="@color/neon_orange" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
