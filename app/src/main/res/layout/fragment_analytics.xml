<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/db_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="100dp">

        <ImageButton
            android:id="@+id/btn_back_analytics"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/db_text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/analytics_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Data Analytics &amp; Insights"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/db_text_primary"
            app:layout_constraintStart_toEndOf="@id/btn_back_analytics"
            app:layout_constraintTop_toTopOf="@id/btn_back_analytics"
            app:layout_constraintBottom_toBottomOf="@id/btn_back_analytics" />

        <!-- Stats Grid with Shadow -->
        <LinearLayout
            android:id="@+id/stats_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btn_back_analytics">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F0F0F0">
                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:text="Total Sold Pigs" android:textSize="12sp" android:textColor="@color/db_text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="1,240" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/db_text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="+12% last month" android:textColor="@color/db_stat_positive_text" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F0F0F0">
                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:text="Population" android:textSize="12sp" android:textColor="@color/db_text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="5,850" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/db_text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="+3% healthy" android:textColor="@color/db_stat_positive_text" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Descriptive Analysis Card with Shadow -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/descriptive_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/stats_layout">
            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView android:text="Descriptive Analysis" android:textStyle="bold" android:textSize="18sp" android:textColor="@color/db_text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Total Feed Consumption" android:textSize="12sp" android:textColor="@color/db_text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="45,200 kg" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/db_text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <View android:layout_marginTop="16dp" android:layout_width="match_parent" android:layout_height="120dp" android:background="@color/db_dark_green" android:alpha="0.1"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Predictive Analysis Card with Shadow -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/predictive_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/descriptive_card">
            <LinearLayout
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView android:text="Predictive Analysis" android:textStyle="bold" android:textSize="18sp" android:textColor="@color/db_text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Estimated Weight Gain (Avg)" android:textSize="12sp" android:textColor="@color/db_text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
                <TextView android:text="115.5 kg" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/neon_orange" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <View android:layout_marginTop="16dp" android:layout_width="match_parent" android:layout_height="120dp" android:background="@color/db_dark_green" android:alpha="0.1"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>