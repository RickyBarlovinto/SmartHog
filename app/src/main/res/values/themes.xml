<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme updated to Material 3 to enable modern Navigation Indicator -->
    <style name="Theme.Smart_Hog" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/dark_orange</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/neon_orange</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/login_bg_peach</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Fix for general text visibility -->
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#000000</item>
    </style>

    <!-- Dashboard Theme (Neon Orange Theme) -->
    <style name="Theme.Smart_Hog.Dashboard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_orange</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/db_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/db_background</item>
        
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#000000</item>

        <item name="materialCardViewStyle">@style/Widget.Material3.CardView.Elevated</item>
    </style>

    <!-- THE STYLE TO MATCH YOUR PIC: Floating Orange Pill Indicator -->
    <style name="App.CustomIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/neon_orange</item>
        <item name="android:width">60dp</item>
        <item name="android:height">40dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.Card.TopRounded" parent="">
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="CircleImageView" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>